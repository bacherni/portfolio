Cell[CellGroupData[{

Cell["(*Elementary examples for Power grid cascade simulations*)", "Title",
 CellChangeTimes->{{3.7162787965569773`*^9, 3.7162788201465826`*^9}}],

Cell["\<\
How to use : Select a cell and hit \[OpenCurlyDoubleQuote]Shift+Enter\
\[CloseCurlyDoubleQuote], confirm \[OpenCurlyDoubleQuote]evaluation of \
initialization cells\[CloseCurlyDoubleQuote] to import the PowerGridCompact \
package
Other networks and power distributions can be easily simulated by changing \
the variables \[OpenCurlyDoubleQuote]matrix\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]power\[CloseCurlyDoubleQuote]. For a systematic \
analysis, all potential \[OpenCurlyDoubleQuote]triggerLine\
\[CloseCurlyDoubleQuote] values and multiple values for \
\[OpenCurlyDoubleQuote]tolerance\[Alpha]\[CloseCurlyDoubleQuote] need to be \
considered.\
\>", "Text",
 CellChangeTimes->{{3.7162815562632046`*^9, 3.7162817214491396`*^9}, {
  3.731741639270453*^9, 3.731741649240687*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{"(*", 
   RowBox[{
   "Simulation", " ", "using", " ", "the", " ", "sample", " ", "5", " ", 
    "node", " ", "system", " ", 
    RowBox[{"(", 
     RowBox[{"from", " ", "in", " ", 
      RowBox[{"Fig", ".", " ", "1"}]}], ")"}]}], "*)"}], "Chapter"]], "Input",
 CellChangeTimes->{{3.716280283875676*^9, 3.7162802963058143`*^9}, {
  3.7162815265518074`*^9, 3.716281526751728*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"(*", 
    RowBox[{
    "Set", " ", "the", " ", "matrix", " ", "and", " ", "power", " ", 
     "distribution", " ", "in", " ", "the", " ", "network"}], "*)"}], "Text"],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "actualCutEdges", ",", "loadPlotT", ",", "flowsExistingLinesOverTime"}], 
    "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"matrix", "=", 
     RowBox[{"AdjacencyMatrix", "@", 
      RowBox[{"EdgeAdd", "[", 
       RowBox[{
        RowBox[{"EdgeAdd", "[", 
         RowBox[{
          RowBox[{"CycleGraph", "[", "5", "]"}], ",", 
          RowBox[{"UndirectedEdge", "[", 
           RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", 
        RowBox[{"UndirectedEdge", "[", 
         RowBox[{"2", ",", "4"}], "]"}]}], "]"}]}]}], ";", 
    RowBox[{"listOfEdges", "=", 
     RowBox[{"EdgeList", "@", 
      RowBox[{"AdjacencyGraph", "@", "matrix"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"power", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"3", "/", "2"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"3", "/", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   StyleBox[
    RowBox[{"(*", 
     RowBox[{
     "Run", " ", "the", " ", "simulation", " ", "and", " ", "also", " ", 
      "store", " ", "the", " ", "trajectory"}], "*)"}], "Text"], 
   "\[IndentingNewLine]", 
   RowBox[{"fiveNodeCascadeResults", "=", 
    RowBox[{"PowerGridCascadeSimulation", "[", 
     RowBox[{
      RowBox[{"couplingMatrix", "\[Rule]", 
       RowBox[{"1.63", "matrix"}]}], ",", 
      RowBox[{"powerVector", "\[Rule]", "power"}], ",", 
      RowBox[{"triggerLine", "->", 
       RowBox[{"{", 
        RowBox[{"2", ",", "4"}], "}"}]}], ",", 
      RowBox[{"tolerance\[Alpha]", "\[Rule]", "0.6"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.716280971529705*^9, 3.716281036417091*^9}, {
