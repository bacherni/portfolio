Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Simulation", " ", "using", " ", "the", " ", "Spnish", " ", 
      "distributed", " ", "grid", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"cutting", " ", "line", " ", "1"}], ",", " ", 
        RowBox[{"as", " ", "in", " ", 
         RowBox[{"Fig", ".", " ", "2"}]}]}], ")"}]}], ":", " ", 
     RowBox[{
     "Takes", " ", "several", " ", "seconds", " ", "to", " ", "a", " ", "few",
       " ", "minutes"}]}], "*)"}], "Chapter"], 
  StyleBox["\[IndentingNewLine]", "Chapter"], 
  StyleBox[
   RowBox[{"(*", 
    RowBox[{"Import", " ", "the", " ", "data"}], "*)"}], "Text"], 
  StyleBox["\[IndentingNewLine]", "Chapter"], 
  RowBox[{
   RowBox[{
    RowBox[{"SetDirectory", "[", 
     RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
    RowBox[{"SetDirectory", "[", "\"\<NetworkData\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"matrix", "=", 
     RowBox[{
     "Import", "[", "\"\<SpanishDistributedPower_Matrix.csv\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"power", "=", 
     RowBox[{"Flatten", "@", 
      RowBox[{
      "Import", "[", "\"\<SpanishDistributedPower_Power.csv\>\"", "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"listOfEdges", "=", 
     RowBox[{"EdgeList", "[", 
      RowBox[{"AdjacencyGraph", "[", 
       RowBox[{"Map", "[", 
        RowBox[{"Unitize", ",", "matrix", ",", "2"}], "]"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   StyleBox[
    RowBox[{"(*", 
     RowBox[{"Run", " ", "the", " ", "simulation"}], "*)"}], "Text"], 
   "\[IndentingNewLine]", 
   RowBox[{"cascadeResult", "=", 
    RowBox[{"PowerGridCascadeSimulation", "[", 
     RowBox[{
      RowBox[{"powerVector", "\[Rule]", "power"}], ",", 
      RowBox[{"couplingMatrix", "\[Rule]", "matrix"}], ",", 
      RowBox[{"triggerLine", "\[Rule]", 
       RowBox[{"listOfEdges", "[", 
        RowBox[{"[", "35", "]"}], "]"}]}], ",", 
      RowBox[{"tolerance\[Alpha]", "\[Rule]", "0.52"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   StyleBox[
    RowBox[{"(*", 
     RowBox[{
     "Plot", " ", "the", " ", "line", " ", "failures", " ", "over", " ", 
      "line"}], "*)"}], "Text"], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"linesCut", "=", 
     RowBox[{
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{
        "\"\<lines cut\>\"", "/.", "\[VeryThinSpace]", "cascadeResult"}], 
        ",", "\"\<lines cut\>\""}], "]"}], "\[LeftDoubleBracket]", 
      RowBox[{
       RowBox[{"1", ";;", "All"}], ",", "2"}], "\[RightDoubleBracket]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"linesCutOverTime", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Cases", "[", 
           RowBox[{"linesCut", ",", 
            RowBox[{"x_", "/;", 
             RowBox[{"x", "<", "t"}]}]}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "20", ",", "0.01"}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"linesCutOverTime", ",", 
     RowBox[{"Frame", "\[Rule]", "True"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<time [s]\>\"", ",", "\"\<\[NumberSign] line failures\>\""}], 
       "}"}]}], ",", 
     RowBox[{"LabelStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"20", ",", "Bold"}], "]"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"Thickness", "[", "0.01", "]"}], ",", 
        RowBox[{
         RowBox[{"ColorData", "[", 
          RowBox[{"3", ",", "\"\<ColorList\>\""}], "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}]}]], "Input",
