Cell[BoxData[
 StyleBox[
  RowBox[{"(*", 
   RowBox[{
   "Simulation", " ", "and", " ", "trajectories", " ", "using", " ", "the", 
    " ", "sample", " ", "5", " ", "node", " ", "system", " ", 
    RowBox[{"(", 
     RowBox[{"as", " ", "in", " ", 
      RowBox[{"Fig", ".", " ", "1"}]}], ")"}]}], "*)"}], "Chapter"]], "Input",
 CellChangeTimes->{{3.716280283875676*^9, 3.7162802963058143`*^9}, {
  3.716281532517384*^9, 3.716281536563939*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"(*", 
    RowBox[{
    "Set", " ", "the", " ", "matrix", " ", "and", " ", "power", " ", 
     "distribution", " ", "in", " ", "the", " ", "network"}], "*)"}], "Text"],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "actualCutEdges", ",", "loadPlotT", ",", "flowsExistingLinesOverTime"}], 
    "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"matrix", "=", 
     RowBox[{"AdjacencyMatrix", "@", 
      RowBox[{"EdgeAdd", "[", 
       RowBox[{
        RowBox[{"EdgeAdd", "[", 
         RowBox[{
          RowBox[{"CycleGraph", "[", "5", "]"}], ",", 
          RowBox[{"UndirectedEdge", "[", 
           RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", 
        RowBox[{"UndirectedEdge", "[", 
         RowBox[{"2", ",", "4"}], "]"}]}], "]"}]}]}], ";", 
    RowBox[{"listOfEdges", "=", 
     RowBox[{"EdgeList", "@", 
      RowBox[{"AdjacencyGraph", "@", "matrix"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"power", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"3", "/", "2"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"3", "/", "2"}]}], "}"}]}], ";", 
    RowBox[{"numberOfNodes", "=", "5"}], ";"}], "\[IndentingNewLine]", 
   StyleBox[
    RowBox[{"(*", 
     RowBox[{
     "Run", " ", "the", " ", "simulation", " ", "and", " ", "also", " ", 
      "store", " ", "the", " ", "trajectory"}], "*)"}], "Text"], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fiveNodeCascadeResults", "=", 
     RowBox[{"PowerGridCascadeSimulation", "[", 
      RowBox[{
       RowBox[{"couplingMatrix", "\[Rule]", 
        RowBox[{"1.63", "matrix"}]}], ",", 
       RowBox[{"powerVector", "\[Rule]", "power"}], ",", 
       RowBox[{"triggerLine", "->", 
        RowBox[{"{", 
         RowBox[{"2", ",", "4"}], "}"}]}], ",", 
       RowBox[{"tolerance\[Alpha]", "\[Rule]", "0.6"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fiveNodeSolution", "=", "PowerGrid`sol"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"angles", "=", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PowerGrid`angle\[Theta]", "[", "i", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "numberOfNodes"}], "}"}]}], "]"}], "/.", 
      RowBox[{"fiveNodeSolution", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";", " ", 
    RowBox[{"linkList", "=", 
     RowBox[{"EdgeList", "[", 
      RowBox[{"AdjacencyGraph", "[", "matrix", "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"linesCut", "=", 
     RowBox[{"(", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{"\"\<lines cut\>\"", "/.", "fiveNodeCascadeResults"}], ",", 
        "\"\<lines cut\>\""}], "]"}], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"actualCutEdges", "[", "t_", "]"}], ":=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"linesCut", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}], "<", "t"}], ",", 
           RowBox[{"Apply", "[", 
            RowBox[{"UndirectedEdge", ",", 
             RowBox[{"linesCut", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], ",", 
           "Nothing"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"1", 
            RowBox[{"Length", "[", "linesCut", "]"}]}]}], "}"}]}], "]"}], ",",
        "Nothing", ",", "Infinity"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"flowsExistingLinesOverTime", "[", 
      RowBox[{"tMax_", ",", "tStepSize_", ",", "angles_", ",", "linkList_"}], 
      "]"}], ":=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"MemberQ", "[", 
              RowBox[{
               RowBox[{"actualCutEdges", "[", "t", "]"}], ",", "link"}], 
              "]"}], ",", "10", ",", 
             RowBox[{"Abs", "@", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"angles", "[", 
                  RowBox[{"[", 
                   RowBox[{"link", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "[", "t", 
                 "]"}], "-", 
                RowBox[{
                 RowBox[{"angles", "[", 
                  RowBox[{"[", 
                   RowBox[{"link", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}], "[", "t", 
                 "]"}]}], "]"}]}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "tMax", ",", "tStepSize"}], "}"}]}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"link", ",", "linkList"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   StyleBox[
    RowBox[{"(*", 
     RowBox[{
     "Plot", " ", "the", " ", "five", " ", "node", " ", "trajectory"}], 
     "*)"}], "Text"], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numberOfNodes", "=", "5"}], ";", 
    RowBox[{"thick", "=", "0.013"}], ";", 
    RowBox[{"markerSize", "=", ".015"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plotStyle", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Thickness", "[", "thick", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"numberOfNodes", "+", "2"}], "}"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"plotStyle", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"linkList", ",", 
          RowBox[{"UndirectedEdge", "@@", 
           RowBox[{"{", 
            RowBox[{"2", ",", "4"}], "}"}]}]}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "]"}], "=", 
     RowBox[{"Directive", "[", 
      RowBox[{
       RowBox[{"Thickness", "[", "thick", "]"}], ",", "Dashed"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plotLegends", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"\"\<F\>\"", ",", 
          RowBox[{"ToString", "[", "#", "]"}]}], "]"}], "&"}], ",", 
       RowBox[{"DeleteCases", "[", 
        RowBox[{"linkList", ",", 
         RowBox[{"UndirectedEdge", "@@", 
          RowBox[{"{", 
